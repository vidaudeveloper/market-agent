# 环境配置模板 · 详见 ENV_SETUP.md
# 首次使用: 复制本文件为 .env，再按 FEISHU-APP-SETUP.md 填入飞书应用凭证

# ========== 飞书（导出飞书必填 — 各自创建企业自建应用）==========
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:8787/api/auth/feishu/callback
# FEISHU_DEFAULT_FOLDER_TOKEN=

# ========== AI（可选 — Hermes/Agent 写报告不需要）==========
# 仅以下场景需要：ai-analyze.js、feishu-export --charts-ai、QuickChart 失败回退 AI 生图
# AI_API_KEY=
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_TIMEOUT=60000
# AI_IMAGE_MODEL=gpt-image-2
# AI_IMAGE_SIZE=1024x1024
# AI_IMAGE_TIMEOUT=120000
