{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VidAU Project Facts",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "project": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "brand_name": {
          "default": "",
          "type": "string"
        },
        "product_name": {
          "default": "",
          "type": "string"
        },
        "hero_sku": {
          "default": "",
          "type": "string"
        },
        "category": {
          "default": "",
          "type": "string"
        },
        "market": {
          "default": "",
          "type": "string"
        },
        "country_code": {
          "default": "",
          "type": "string"
        },
        "currency": {
          "default": "USD",
          "type": "string"
        },
        "target_audience": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "objectives": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "channels": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "budget": {
          "default": {
            "amount": null,
            "period": "",
            "currency": "USD"
          },
          "type": "object",
          "properties": {
            "amount": {
              "default": null,
              "anyOf": [
                {
                  "type": "number",
                  "minimum": 0
                },
                {
                  "type": "null"
                }
              ]
            },
            "period": {
              "default": "",
              "type": "string"
            },
            "currency": {
              "default": "USD",
              "type": "string"
            }
          }
        },
        "timeline": {
          "default": {
            "start_date": "",
            "end_date": "",
            "horizon_days": null
          },
          "type": "object",
          "properties": {
            "start_date": {
              "default": "",
              "type": "string"
            },
            "end_date": {
              "default": "",
              "type": "string"
            },
            "horizon_days": {
              "default": null,
              "anyOf": [
                {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "inputs": {
      "default": {
        "urls": [],
        "user_materials": []
      },
      "type": "object",
      "properties": {
        "urls": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "label": {
                "default": "",
                "type": "string"
              }
            },
            "required": [
              "type",
              "url"
            ]
          }
        },
        "user_materials": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "default": "",
                "type": "string"
              },
              "received_at": {
                "default": "",
                "type": "string"
              }
            },
            "required": [
              "path"
            ]
          }
        }
      }
    },
    "entities": {
      "default": {
        "products": [],
        "sellers": [],
        "competitors": [],
        "creators": [],
        "videos": []
      },
      "type": "object",
      "properties": {
        "products": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "sellers": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "competitors": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "creators": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        },
        "videos": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        }
      }
    },
    "evidence": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "source_name": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "default": "",
            "type": "string"
          },
          "retrieved_at": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "verified",
              "estimated",
              "inferred",
              "unverified"
            ]
          },
          "entity_refs": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fields": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "note": {
            "default": "",
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "source_name",
          "retrieved_at",
          "status"
        ]
      }
    },
    "facts": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "topic": {
            "type": "string",
            "minLength": 1
          },
          "metric": {
            "type": "string",
            "minLength": 1
          },
          "value": {},
          "unit": {
            "default": "",
            "type": "string"
          },
          "period": {
            "default": "",
            "type": "string"
          },
          "entity_ref": {
            "default": "",
            "type": "string"
          },
          "evidence_ids": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "verified",
              "estimated",
              "inferred",
              "unverified"
            ]
          },
          "note": {
            "default": "",
            "type": "string"
          }
        },
        "required": [
          "id",
          "topic",
          "metric",
          "value",
          "status"
        ]
      }
    },
    "screenshots": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "page_url": {
            "default": "",
            "type": "string"
          },
          "captured_at": {
            "type": "string",
            "minLength": 1
          },
          "entity_ref": {
            "default": "",
            "type": "string"
          },
          "evidence_id": {
            "default": "",
            "type": "string"
          },
          "caption": {
            "default": "",
            "type": "string"
          }
        },
        "required": [
          "id",
          "path",
          "captured_at"
        ]
      }
    },
    "assumptions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "basis": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "default": "medium",
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "required": [
          "id",
          "statement",
          "basis"
        ]
      }
    },
    "gaps": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "field": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "blocking_skills": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "field",
          "reason"
        ]
      }
    },
    "workflow": {
      "default": {
        "current_stage": "intake",
        "completed_stages": [],
        "last_gate": {
          "skill": "",
          "passed": false,
          "checked_at": ""
        }
      },
      "type": "object",
      "properties": {
        "current_stage": {
          "default": "intake",
          "type": "string"
        },
        "completed_stages": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "last_gate": {
          "default": {
            "skill": "",
            "passed": false,
            "checked_at": ""
          },
          "type": "object",
          "properties": {
            "skill": {
              "default": "",
              "type": "string"
            },
            "passed": {
              "default": false,
              "type": "boolean"
            },
            "checked_at": {
              "default": "",
              "type": "string"
            }
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "schema_version",
    "project",
    "generated_at",
    "updated_at"
  ],
  "additionalProperties": false
}
