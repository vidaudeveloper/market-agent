# AI营销全案策划师 — 环境配置
# 飞书应用凭证供团队共用；各用户导出仍需本机 OAuth（auth/feishu-user.json）
# 说明见 ENV_SETUP.md

# === AI ===
AI_API_KEY=
# 填基础地址即可，脚本会自动请求 {AI_BASE_URL}/chat/completions
AI_BASE_URL=https://www.tokenware.ai/v1
AI_MODEL=deepseek-v4-pro
AI_TIMEOUT=60000
AI_IMAGE_MODEL=gpt-image-2
AI_IMAGE_SIZE=1024x1024
AI_IMAGE_TIMEOUT=120000

# === 飞书（导出飞书必填；用户各自浏览器 OAuth，文档进各自账号）===
FEISHU_APP_ID=cli_aaa66f8dc7389bd4
